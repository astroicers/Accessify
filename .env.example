# Accessify 部署設定範本（T701 / ADR-002）。複製為 .env 後調整。
# ⚠ 機密一律以 0600 secrets 檔注入（install.sh 產生於 ./secrets/），切勿在此或映像中填入明文（ADR-008）。

# ── 對外（前置反代 / 防火牆把關）────────────────────────────
APP_PORT=8443                 # 主機對外埠（映射到容器 8443）
ACCESSIFY_TAG=local           # 映像 tag（離線載入後設定；install.sh 會帶入）
TZ=Asia/Taipei                # 容器時區（ADR-010：排程相對間隔、報表時間顯示）

# ── API ───────────────────────────────────────────────
SESSION_TIMEOUT_MIN=30        # session 逾時（分鐘）
ADMIN_USERNAME=admin          # 首位 admin 帳號；密碼於首啟自動產生一次性並強制改密（勿設固定密碼）
# APP_VERSION=0.1.0           # 顯示於 /api/status

# ── 掃描（worker）─────────────────────────────────────
NAV_TIMEOUT_MS=15000          # 單頁 navigation timeout
MAX_PAGES=200                 # 單任務最大頁數
CHROMIUM_SANDBOX=true         # 容器內保持 Chromium sandbox（ADR-009）；非 root 測試環境才設 false

# ── 佇列 / 排程（worker）──────────────────────────────
SCHEDULER_TICK_MS=60000       # 排程輪詢間隔
WORKER_POLL_MS=1000           # job 輪詢間隔
LEASE_MS=60000               # job 租約 / 心跳
MAX_ATTEMPTS=3               # job 失敗重試上限
BUSY_TIMEOUT_MS=5000         # SQLite busy_timeout（ADR-003）

# ── 資料保留與磁碟治理（worker；ADR-011）──────────────
RETENTION_DAYS=0             # 逾期掃描+報表自動清除天數（0=停用刪除，仍週期 WAL checkpoint）
RETENTION_TICK_MS=86400000   # 保留掃描週期（預設每日）

# ── 機密（由 install.sh 隨機產生並寫入 ./secrets/，權限 0600；本檔切勿填值）──
#   ./secrets/cookie_secret   → COOKIE_SECRET_FILE（cookie 簽章金鑰，ADR-008）
#   ./secrets/tls_cert.pem    → TLS_CERT_PATH（內網 TLS 憑證，ADR-008）
#   ./secrets/tls_key.pem     → TLS_KEY_PATH（私鑰）

# ── 備註（誠實標示，避免誤設）──────────────────────────
#  • 掃描白名單存於 DB（settings.scan_whitelist），由登入後「設定」頁或 API 維護，非由本檔讀取。
#  • 內網 SMTP 外送通知尚未接上（屬新執行期相依 + 出站路徑，待 ADR-012）；站內通知已可用，無需設定。
