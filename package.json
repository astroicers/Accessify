{
  "name": "accessify",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "地端、無網際網路（軍網）無障礙網頁檢測工具",
  "engines": {
    "node": ">=22 <23"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "eslint-plugin-i18next": "^6.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^3.0.0"
  }
}
